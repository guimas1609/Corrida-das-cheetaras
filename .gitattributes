# Vídeo e modelos 3D em assets-brutos/ (fontes originais, nunca lidos pelo
# build da Vercel) ficam em Git LFS — podem ficar grandes.
*.webm filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.glb filter=lfs diff=lfs merge=lfs -text
*.gltf filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.hdr filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text

# Tudo em site/ (inclusive site/public/) fica como blob normal do Git: a
# Vercel não busca objetos do Git LFS no build, então qualquer arquivo que o
# site sirva ou processe precisa estar acessível direto (mesmo motivo por
# trás de tirar os PNGs do LFS — ver commit "Remove imagens do Git LFS").
site/**/*.webm -filter -diff -merge -text
site/**/*.mov -filter -diff -merge -text
site/**/*.mp4 -filter -diff -merge -text
site/**/*.glb -filter -diff -merge -text
site/**/*.gltf -filter -diff -merge -text
site/**/*.fbx -filter -diff -merge -text
site/**/*.obj -filter -diff -merge -text
site/**/*.hdr -filter -diff -merge -text
site/**/*.exr -filter -diff -merge -text

# Imagens ficam como blobs normais do Git em qualquer lugar (mesmo motivo).
*.png -text
*.jpg -text
*.jpeg -text
*.webp -text
*.gif -text
*.psd -text
*.ai -text
